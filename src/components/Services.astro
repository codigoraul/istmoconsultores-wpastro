---
const services = [
  {
    num: '01',
    id: 'estrategia',
    title: 'Estrategia Pública y Reputacional',
    description: 'Diseñamos estrategias de relacionamiento institucional y comunicación que permiten desenvolverse de manera legítima y efectiva en entornos político-regulatorios complejos.',
    subareas: [
      'Asuntos Públicos',
      'Comunicación Estratégica',
    ],
  },
  {
    num: '02',
    id: 'innovacion',
    title: 'Innovación Institucional y Corporativa',
    description: 'Fortalecemos marcos de cumplimiento, integridad y gobernanza, acompañando procesos de transformación con coherencia entre estrategia, cultura y comunicación.',
    subareas: [
      'Compliance y Gobernanza',
      'Cambio Organizacional y Formación Corporativa',
    ],
  },
  {
    num: '03',
    id: 'proyectos',
    title: 'Desarrollo y Viabilidad de Proyectos',
    description: 'Apoyamos la estructuración de proyectos de inversión, implementamos estrategias territoriales y acompañamos a las organizaciones en la optimización de su capital.',
    subareas: [
      'Formulación y Evaluación de Proyectos',
      'Desarrollo Territorial y Relaciones Comunitarias',
      'Estrategia y Viabilidad de Inversiones',
    ],
  },
];
---

<section class="bg-white py-20" id="servicios">
  <div class="container">
    <p class="eyebrow">Áreas de práctica</p>
    <h2 class="section-title">Tres pilares estratégicos</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-2">
      {services.map(svc => (
        <article class="border border-gray-200 border-t-[3px] border-t-corp rounded p-7 flex flex-col gap-4 hover:shadow-md transition-shadow">
          <div>
            <span class="text-[11px] text-medio font-medium tracking-widest block mb-2">{svc.num}</span>
            <h3 class="text-lg font-medium text-negro leading-snug">{svc.title}</h3>
          </div>
          <ul class="flex flex-col gap-2 flex-1">
            {svc.subareas.map(area => (
              <li class="flex items-start gap-2 text-[13px] text-negro font-medium leading-snug">
                <span class="w-1.5 h-1.5 rounded-full bg-corp flex-shrink-0 mt-1.5"></span>
                {area}
              </li>
            ))}
          </ul>
          <a href={`/servicios/#${svc.id}`} class="text-[13px] text-corp font-medium hover:text-marino transition-colors mt-2">
            Ver detalle completo →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
