---
const services = [
  {
    num: '01',
    id: 'estrategia',
    title: 'Estrategia Pública y Reputacional',
    description: 'Diseñamos estrategias de relacionamiento institucional y comunicación que permiten desenvolverse de manera legítima y efectiva en entornos político-regulatorios complejos.',
    items: [
      'Diseño de estrategias de relacionamiento público-privado',
      'Monitoreo y análisis legislativo y regulatorio',
      'Análisis prospectivo del entorno político y económico',
      'Mapeo y perfilamiento de stakeholders',
      'Posicionamiento ante autoridades y organismos multilaterales',
      'Diagnósticos reputacionales y gestión de crisis',
      'Monitoreo de marca en entornos digitales',
    ],
  },
  {
    num: '02',
    id: 'innovacion',
    title: 'Innovación Institucional y Corporativa',
    description: 'Fortalecemos marcos de cumplimiento, integridad y gobernanza, acompañando procesos de transformación con coherencia entre estrategia, cultura y comunicación.',
    items: [
      'Diagnóstico de riesgos de compliance y gobernanza',
      'Diseño de modelos de prevención y cumplimiento',
      'Códigos de ética y conducta institucional',
      'Protocolos de relacionamiento con stakeholders',
      'Capacitación en integridad y estándares ESG',
      'Acompañamiento en cambio organizacional',
      'Planes de comunicación interna',
    ],
  },
  {
    num: '03',
    id: 'proyectos',
    title: 'Desarrollo y Viabilidad de Proyectos',
    description: 'Apoyamos la estructuración de proyectos de inversión, implementamos estrategias territoriales y acompañamos a las organizaciones en la optimización de su capital.',
    items: [
      'Estructuración integral de proyectos de inversión',
      'Modelamiento de negocios y viabilidad económica',
      'Evaluación de riesgos regulatorios y territoriales',
      'Estrategias de relacionamiento comunitario',
      'Diseño y fortalecimiento de modelos asociativos',
      'Asesoría en inversiones tradicionales y DeFi',
      'Programas de impacto socioeconómico territorial',
    ],
  },
];
---

<section class="bg-white py-20" id="servicios">
  <div class="container">
    <p class="eyebrow">Áreas de práctica</p>
    <h2 class="section-title">Tres pilares estratégicos</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-2">
      {services.map(svc => (
        <article class="border border-gray-200 border-t-[3px] border-t-corp rounded p-7 flex flex-col gap-4 hover:shadow-md transition-shadow">
          <div>
            <span class="text-[11px] text-medio font-medium tracking-widest block mb-2">{svc.num}</span>
            <h3 class="text-lg font-medium text-negro leading-snug">{svc.title}</h3>
          </div>
          <p class="text-[13px] text-gris leading-relaxed">{svc.description}</p>
          <ul class="flex flex-col gap-2 flex-1">
            {svc.items.map(item => (
              <li class="flex items-start gap-2 text-[13px] text-gris leading-snug">
                <span class="w-1.5 h-1.5 rounded-full bg-medio flex-shrink-0 mt-1.5"></span>
                {item}
              </li>
            ))}
          </ul>
          <a href={`/servicios#${svc.id}`} class="text-[13px] text-corp font-medium hover:text-marino transition-colors mt-2">
            Ver más →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
