---
import { getSiteOptions } from '../lib/wordpress';
const opts = await getSiteOptions();
const stats = opts.stats;
---

<section class="bg-corp py-5">
  <div class="container flex flex-wrap justify-around gap-4">
    {stats.map(s => (
      <div class="text-center">
        <span class="block text-2xl font-medium text-white">{s.valor}</span>
        <span class="block text-[10px] tracking-widest uppercase text-white/60 mt-0.5">{s.label}</span>
      </div>
    ))}
  </div>
</section>
