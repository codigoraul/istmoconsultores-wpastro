---
---

<section class="relative bg-marino overflow-hidden py-32 md:py-40">
  <!-- Background slider -->
  <div class="absolute inset-0 z-0">
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-1000">
      <img src="/images/slider-1.webp" alt="" class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-1000">
      <img src="/images/slider-2.webp" alt="" class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-1000">
      <img src="/images/slider-3.webp" alt="" class="w-full h-full object-cover opacity-30" />
    </div>
  </div>
  
  <!-- Overlay oscuro -->
  <div class="absolute inset-0 bg-black/40 z-[1]"></div>

  <div class="container relative z-10">
    <div class="max-w-2xl">
      <!-- eyebrow -->
      <div class="flex items-center gap-3 mb-5 hero-animate opacity-0 translate-y-4" style="animation-delay: 0.1s">
        <span class="block w-9 h-0.5 bg-medio flex-shrink-0 self-start mt-1"></span>
        <span class="text-cielo text-[11px] tracking-[0.12em] uppercase font-medium leading-relaxed">
          Asuntos Públicos · Comunicación Estratégica<br />
          Desarrollo Territorial · Innovación Institucional
        </span>
      </div>

      <h1 class="font-serif text-4xl md:text-5xl font-medium text-white leading-tight mb-5 hero-animate opacity-0 translate-y-4" style="animation-delay: 0.3s">
        Conectamos visiones,<br />
        <em class="not-italic text-cielo">construimos valor</em>
      </h1>

      <p class="text-white/75 text-base leading-relaxed max-w-lg mb-8 hero-animate opacity-0 translate-y-4" style="animation-delay: 0.5s">
        Transformamos la complejidad institucional, política y territorial
        en ventajas estratégicas para nuestros clientes en América Latina y el Caribe.
      </p>

      <div class="flex flex-wrap gap-4 hero-animate opacity-0 translate-y-4" style="animation-delay: 0.7s">
        <a href="/servicios" class="btn-primary">Nuestros servicios</a>
        <a href="/nosotros" class="btn-ghost">Quiénes somos</a>
      </div>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  let currentSlide = 0;

  function showSlide(index: number) {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.remove('opacity-0');
        slide.classList.add('opacity-100');
      } else {
        slide.classList.remove('opacity-100');
        slide.classList.add('opacity-0');
      }
    });
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % slides.length;
    showSlide(currentSlide);
  }

  showSlide(0);
  setInterval(nextSlide, 5000);

  // Activar animaciones de entrada
  const animatedElements = document.querySelectorAll('.hero-animate');
  setTimeout(() => {
    animatedElements.forEach(el => {
      el.classList.remove('opacity-0', 'translate-y-4');
      el.classList.add('opacity-100', 'translate-y-0');
    });
  }, 100);
</script>

<style>
  .hero-animate {
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
</style>
