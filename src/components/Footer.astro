---
import { getSiteOptions } from '../lib/wordpress';

const year = new Date().getFullYear();
const opts = await getSiteOptions();
---

<footer class="bg-[#253F6F]">
  <div class="container pt-[66px] pb-14 grid grid-cols-1 md:grid-cols-3 gap-10 border-b border-white/10">

    <!-- Columna 1: Marca -->
    <div>
      <img src="/logo-ISTMO-v.svg" alt="Istmo Consultores" width="260" height="100"
        class="mb-4 brightness-0 invert opacity-60" style="height:74px; width:auto;" />
      <p class="text-[13px] text-white/85 italic mb-4">{opts.footer_tagline}</p>
      <p class="text-[13px] text-white/85 leading-relaxed">{opts.footer_descripcion}</p>
    </div>

    <!-- Columna 2: Áreas de práctica + Sectores -->
    <div>
      <h3 class="text-[12px] tracking-widest uppercase text-cielo font-medium mb-5">Áreas de práctica</h3>
      <ul class="flex flex-col gap-3 mb-7">
        {[
          {label: 'Asuntos Públicos', href: '/servicios#estrategia'},
          {label: 'Innovación Institucional y Corporativa', href: '/servicios#innovacion'},
          {label: 'Desarrollo territorial y viabilidad de proyectos', href: '/servicios#proyectos'},
        ].map(s => (
          <li>
            <a href={s.href} class="text-[13px] text-white/90 hover:text-white/95 transition-colors leading-snug block">
              {s.label}
            </a>
          </li>
        ))}
      </ul>
      <h3 class="text-[12px] tracking-widest uppercase text-cielo font-medium mb-3">Sectores</h3>
      <p class="text-[13px] text-white/85 leading-relaxed">
        Energía · Minería · Infraestructura · Desarrollo urbano · Políticas públicas · Innovación y sostenibilidad
      </p>
    </div>

    <!-- Columna 3: Empresa + Contacto -->
    <div>
      <h3 class="text-[12px] tracking-widest uppercase text-cielo font-medium mb-5">Empresa</h3>
      <ul class="flex flex-col gap-3 mb-8">
        {[
          {label: 'Quiénes somos', href: '/nosotros'},
          {label: 'Equipo directivo', href: '/equipo'},
          {label: 'Sectores de intervención', href: '/sectores'},
          {label: 'Contacto', href: '/contacto'},
        ].map(l => (
          <li>
            <a href={l.href} class="text-[13px] text-white/90 hover:text-white/95 transition-colors">{l.label}</a>
          </li>
        ))}
      </ul>
      <h3 class="text-[12px] tracking-widest uppercase text-cielo font-medium mb-4">Contacto</h3>
      <ul class="flex flex-col gap-2.5">
        <li>
          <a href={`mailto:${opts.email_contacto}`} class="text-[13px] text-white/90 hover:text-white/95 transition-colors">
            {opts.email_contacto}
          </a>
        </li>
        {opts.telefono && (
          <li class="text-[13px] text-white/90" set:html={opts.telefono.replace(/\n/g, ' · ')} />
        )}
        <li class="text-[13px] text-white/85">{opts.ubicacion} · América Latina y el Caribe</li>
        {opts.linkedin && (
          <li>
            <a href={opts.linkedin} target="_blank" rel="noopener"
              class="text-[13px] text-white/90 hover:text-white/95 transition-colors">
              LinkedIn
            </a>
          </li>
        )}
      </ul>
    </div>

  </div>

  <div class="container py-5 flex flex-wrap justify-between items-center gap-2 text-[12px] text-white/50">
    <span>© {year} Istmo Consultores · Todos los derechos reservados</span>
    <div class="flex items-center gap-4">
      <span>Santiago, Chile</span>
      <span>·</span>
      <a href="https://diseñopaginas.cl" target="_blank" rel="noopener" class="hover:text-white/40 transition-colors">
        por diseñopaginas.cl
      </a>
    </div>
  </div>
</footer>
