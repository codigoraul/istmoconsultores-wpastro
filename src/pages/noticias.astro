---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';

// Credenciales WordPress (Application Password)
const WP_USER = import.meta.env.WP_USER;
const WP_APP_PASSWORD = import.meta.env.WP_APP_PASSWORD;
const authHeader = WP_USER && WP_APP_PASSWORD
  ? 'Basic ' + btoa(`${WP_USER}:${WP_APP_PASSWORD}`)
  : '';

const WP_API_URL = 'https://istmoconsultores.cl/admin/wp-json/wp/v2/posts?_embed&per_page=20';
let posts: any[] = [];
let error: string | null = null;

try {
  const response = await fetch(WP_API_URL, {
    headers: authHeader ? { 'Authorization': authHeader } : {}
  });
  if (response.ok) {
    posts = await response.json();

    // Para cada post, obtener imagen con auth si _embed la bloqueó
    for (const post of posts) {
      if (post.featured_media) {
        const embeddedMedia = post._embedded?.['wp:featuredmedia']?.[0];
        const hasError = !embeddedMedia || embeddedMedia?.code === 'rest_forbidden' || !embeddedMedia?.source_url;

        if (hasError) {
          try {
            const mediaResponse = await fetch(
              `https://istmoconsultores.cl/admin/wp-json/wp/v2/media/${post.featured_media}`,
              { headers: authHeader ? { 'Authorization': authHeader } : {} }
            );
            if (mediaResponse.ok) {
              const media = await mediaResponse.json();
              post.featured_image_url = media.source_url;
            }
          } catch (err) {
            console.error('Error fetching media:', err);
          }
        }
      }
    }
  }
} catch (e) {
  error = 'No se pudieron cargar las noticias';
  console.error(e);
}
---

<Layout title="Noticias — Istmo Consultores">
  <Header />
  <main>
    <PageHero
      title="Noticias"
      subtitle="Actualidad, análisis y perspectivas estratégicas"
      variant="edificios"
      image="/images/title-noticias.webp"
      overlayOpacity={0.72}
    />

    <!-- Grid de noticias -->
    <section class="bg-white py-20">
      <div class="container">
        {error && (
          <div class="max-w-4xl mx-auto text-center">
            <p class="text-base text-gris">{error}</p>
          </div>
        )}

        {!error && posts.length === 0 && (
          <div class="max-w-4xl mx-auto text-center">
            <p class="text-base text-gris">No hay noticias publicadas aún.</p>
          </div>
        )}

        {posts.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post: any) => {
              const imageUrl = post._embedded?.['wp:featuredmedia']?.[0]?.source_url || post.featured_image_url;
              return (
              <article class="border border-gray-200 rounded overflow-hidden hover:shadow-lg transition-shadow bg-white">
                {imageUrl && (
                  <img 
                    src={imageUrl} 
                    alt={post.title.rendered}
                    class="w-full h-48 object-cover"
                  />
                )}
                <div class="p-6">
                  <h2 class="font-serif text-xl font-medium text-negro mb-3 leading-snug">
                    <a href={`/noticias/${post.slug}/`} class="hover:text-corp transition-colors">
                      {post.title.rendered}
                    </a>
                  </h2>
                  <div 
                    class="text-sm text-gris mb-4 line-clamp-5" 
                    style="display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden;"
                    set:html={post.excerpt.rendered} 
                  />
                  <a href={`/noticias/${post.slug}/`} class="text-sm text-corp font-medium hover:text-marino transition-colors">
                    Leer más →
                  </a>
                </div>
              </article>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
