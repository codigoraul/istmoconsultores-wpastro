---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Credenciales WordPress (Application Password)
const WP_USER = import.meta.env.WP_USER;
const WP_APP_PASSWORD = import.meta.env.WP_APP_PASSWORD;
const authHeader = WP_USER && WP_APP_PASSWORD
  ? 'Basic ' + btoa(`${WP_USER}:${WP_APP_PASSWORD}`)
  : '';

const fetchOpts = { headers: authHeader ? { 'Authorization': authHeader } : {} };

const { slug } = Astro.params;
let post: any = null;
let error: string | null = null;

try {
  const response = await fetch(
    `https://istmoconsultores.cl/admin/wp-json/wp/v2/posts?slug=${slug}&_embed`,
    fetchOpts
  );
  if (response.ok) {
    const posts = await response.json();
    post = posts[0] || null;

    if (post && post.featured_media) {
      const embeddedMedia = post._embedded?.['wp:featuredmedia']?.[0];
      const hasError = !embeddedMedia || embeddedMedia?.code === 'rest_forbidden' || !embeddedMedia?.source_url;

      if (hasError) {
        try {
          const mediaResponse = await fetch(
            `https://istmoconsultores.cl/admin/wp-json/wp/v2/media/${post.featured_media}`,
            fetchOpts
          );
          if (mediaResponse.ok) {
            const media = await mediaResponse.json();
            post.featured_image_url = media.source_url;
          }
        } catch (err) {
          console.error('Error fetching media:', err);
        }
      }
    }
  }
} catch (e) {
  error = 'No se pudo cargar la noticia';
  console.error(e);
}

// Get all posts for static generation
export async function getStaticPaths() {
  const WP_USER = import.meta.env.WP_USER;
  const WP_APP_PASSWORD = import.meta.env.WP_APP_PASSWORD;
  const authHeader = WP_USER && WP_APP_PASSWORD
    ? 'Basic ' + btoa(`${WP_USER}:${WP_APP_PASSWORD}`)
    : '';

  try {
    const response = await fetch(
      'https://istmoconsultores.cl/admin/wp-json/wp/v2/posts?per_page=100',
      { headers: authHeader ? { 'Authorization': authHeader } : {} }
    );
    const posts = await response.json();
    return posts.map((post: any) => ({ params: { slug: post.slug } }));
  } catch (e) {
    console.error('Error fetching posts for paths:', e);
    return [];
  }
}

const featuredImage = post?._embedded?.['wp:featuredmedia']?.[0]?.source_url || post?.featured_image_url;
---

<Layout title={post ? `${post.title.rendered} — Istmo Consultores` : 'Noticia — Istmo Consultores'}>
  <Header />
  <main>
    {error || !post ? (
      <section class="bg-white py-20">
        <div class="container max-w-4xl text-center">
          <h1 class="font-serif text-3xl font-medium text-negro mb-4">Noticia no encontrada</h1>
          <p class="text-base text-gris mb-8">La noticia que buscas no existe o ha sido eliminada.</p>
          <a href="/noticias/" class="btn-primary">Ver todas las noticias</a>
        </div>
      </section>
    ) : (
      <>
        <!-- Artículo: imagen sticky 30% + contenido 70% -->
        <section class="bg-white py-12">
          <div class="container">

            <!-- Volver -->
            <a href="/noticias/" class="text-sm text-corp font-medium hover:text-marino transition-colors mb-8 inline-block">
              ← Volver a noticias
            </a>

            <div class="flex flex-col md:flex-row gap-10 items-start">

              <!-- COLUMNA IZQUIERDA: título + contenido 64% -->
              <div class={featuredImage ? 'w-full md:w-[64%]' : 'w-full'}>

                <!-- Título y meta -->
                <h1 class="font-serif text-2xl md:text-3xl font-medium text-negro mb-2 leading-tight">
                  {post.title.rendered}
                </h1>
                {post._embedded?.['wp:term']?.[0]?.[0] && (
                  <div class="text-sm text-corp mb-6">
                    {post._embedded['wp:term'][0][0].name}
                  </div>
                )}

                <hr class="border-gray-200 mb-6" />

                <!-- Contenido del artículo -->
                <div
                  class="text-base text-gris leading-relaxed space-y-4
                    [&_h2]:font-serif [&_h2]:text-xl [&_h2]:font-medium [&_h2]:text-negro [&_h2]:mt-8 [&_h2]:mb-3
                    [&_h3]:font-serif [&_h3]:text-lg [&_h3]:font-medium [&_h3]:text-negro [&_h3]:mt-6 [&_h3]:mb-2
                    [&_p]:mb-4
                    [&_strong]:text-negro [&_strong]:font-semibold
                    [&_a]:text-corp hover:[&_a]:text-marino
                    [&_ul]:list-disc [&_ul]:pl-5 [&_li]:mb-1
                    [&_ol]:list-decimal [&_ol]:pl-5
                    [&_img]:rounded [&_img]:shadow-md [&_img]:my-6"
                  set:html={post.content.rendered}
                />
              </div>

              <!-- COLUMNA DERECHA: imagen sticky 36% -->
              {featuredImage && (
                <div class="w-full md:w-[36%] shrink-0 md:sticky md:top-24">
                  <img
                    src={featuredImage}
                    alt={post.title.rendered}
                    class="w-full h-auto rounded shadow-lg"
                  />
                </div>
              )}

            </div>
          </div>
        </section>

        <!-- Botón volver -->
        <section class="bg-fondo py-12">
          <div class="container max-w-4xl text-center">
            <a href="/noticias/" class="btn-primary">Ver más noticias</a>
          </div>
        </section>
      </>
    )}
  </main>
  <Footer />
</Layout>
