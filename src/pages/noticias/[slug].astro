---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const { slug } = Astro.params;

// Fetch post from WordPress API
const WP_API_URL = `https://istmoconsultores.cl/admin/wp-json/wp/v2/posts?slug=${slug}&_embed`;
let post: any = null;
let error: string | null = null;

try {
  const response = await fetch(WP_API_URL);
  if (response.ok) {
    const posts = await response.json();
    post = posts[0] || null;
    
    // Fetch image if _embed doesn't work
    if (post && post.featured_media && !post._embedded?.['wp:featuredmedia']) {
      try {
        const mediaResponse = await fetch(`https://istmoconsultores.cl/admin/wp-json/wp/v2/media/${post.featured_media}`);
        if (mediaResponse.ok) {
          const media = await mediaResponse.json();
          post.featured_image_url = media.source_url;
        }
      } catch (err) {
        console.error('Error fetching media:', err);
      }
    }
  }
} catch (e) {
  error = 'No se pudo cargar la noticia';
  console.error(e);
}

// Get all posts for static generation
export async function getStaticPaths() {
  try {
    const response = await fetch('https://istmoconsultores.cl/admin/wp-json/wp/v2/posts?_embed');
    const posts = await response.json();
    
    return posts.map((post: any) => ({
      params: { slug: post.slug },
    }));
  } catch (e) {
    console.error('Error fetching posts:', e);
    return [];
  }
}

const featuredImage = post?._embedded?.['wp:featuredmedia']?.[0]?.source_url || post?.featured_image_url;
---

<Layout title={post ? `${post.title.rendered} — Istmo Consultores` : 'Noticia — Istmo Consultores'}>
  <Header />
  <main>
    {error || !post ? (
      <section class="bg-white py-20">
        <div class="container max-w-4xl text-center">
          <h1 class="font-serif text-3xl font-medium text-negro mb-4">Noticia no encontrada</h1>
          <p class="text-base text-gris mb-8">La noticia que buscas no existe o ha sido eliminada.</p>
          <a href="/noticias/" class="btn-primary">Ver todas las noticias</a>
        </div>
      </section>
    ) : (
      <>
        <!-- Hero con imagen y título -->
        <section class="bg-fondo py-16">
          <div class="container">
            <div class="flex flex-col md:flex-row gap-8 items-start">
              <!-- Imagen - 40% -->
              {featuredImage && (
                <div class="w-full md:w-2/5">
                  <img 
                    src={featuredImage} 
                    alt={post.title.rendered}
                    class="w-full h-auto rounded shadow-lg"
                  />
                </div>
              )}
              
              <!-- Título y descripción - 60% -->
              <div class={featuredImage ? 'w-full md:w-3/5' : 'w-full'}>
                <a href="/noticias/" class="text-sm text-corp font-medium hover:text-marino transition-colors mb-4 inline-block">
                  ← Volver a noticias
                </a>
                <h1 class="font-serif text-4xl md:text-5xl font-medium text-negro mb-4 leading-tight">
                  {post.title.rendered}
                </h1>
                <div class="flex items-center gap-4 text-sm text-gris">
                  <span>{new Date(post.date).toLocaleDateString('es-ES', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                  })}</span>
                  {post._embedded?.['wp:term']?.[0]?.[0] && (
                    <>
                      <span>•</span>
                      <span class="text-corp">{post._embedded['wp:term'][0][0].name}</span>
                    </>
                  )}
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- Contenido del artículo -->
        <section class="bg-white py-16">
          <div class="container max-w-4xl">
            <div class="prose prose-lg max-w-none
              prose-headings:font-serif prose-headings:text-negro
              prose-h2:text-3xl prose-h2:font-medium prose-h2:mb-4 prose-h2:mt-8
              prose-h3:text-2xl prose-h3:font-medium prose-h3:mb-3 prose-h3:mt-6
              prose-p:text-base prose-p:text-gris prose-p:leading-relaxed prose-p:mb-4
              prose-a:text-corp prose-a:no-underline hover:prose-a:text-marino
              prose-strong:text-negro prose-strong:font-semibold
              prose-ul:text-gris prose-ol:text-gris
              prose-li:mb-2
              prose-img:rounded prose-img:shadow-md"
              set:html={post.content.rendered}
            />
          </div>
        </section>

        <!-- Botón volver -->
        <section class="bg-fondo py-12">
          <div class="container max-w-4xl text-center">
            <a href="/noticias/" class="btn-primary">Ver más noticias</a>
          </div>
        </section>
      </>
    )}
  </main>
  <Footer />
</Layout>
