---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
import { getEquipo } from '../lib/wordpress';

const team = await getEquipo();
console.log('EQUIPO:', team.map(m => m.name));
---

<Layout title="Equipo — Istmo Consultores">
  <Header />
  <main>
    <PageHero
      variant="reunion"
      title="Equipo"
      subtitle="Criterio estratégico y experiencia multidisciplinaria"
      image="/images/title-equipo.webp"
    />

    <section id="directivo" class="bg-white py-20">
      <div class="container">
        <p class="eyebrow">Equipo directivo</p>
        <h2 class="section-title">Liderazgo con visión estratégica</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
          <p class="text-sm text-gris leading-relaxed">
            El principal activo de Istmo Consultores es el criterio estratégico, la experiencia y la capacidad analítica de su equipo. La firma opera bajo un modelo ágil que combina un núcleo directivo con una red de especialistas asociados en América Latina y el Caribe.
          </p>
          <p class="text-sm text-gris leading-relaxed">
            El equipo directivo integra experiencia en organismos internacionales, gestión legislativa, regulación pública, comunicación estratégica, desarrollo territorial y estructuración de proyectos de inversión, permitiendo abordar desafíos complejos desde una perspectiva multidisciplinaria y orientada a resultados.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {team.map(m => (
            <article class="bg-white border border-gray-200 rounded overflow-hidden hover:shadow-md transition-shadow">
              <div class="h-48 bg-marino flex items-center justify-center overflow-hidden">
                {m.photo ? (
                  <img
                    src={m.photo}
                    alt={m.name}
                    class="w-full h-full object-cover object-top"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                ) : null}
                <div class={`w-16 h-16 rounded-full border-2 border-medio flex items-center justify-center text-xl font-medium text-cielo ${m.photo ? 'hidden' : 'flex'}`}>
                  {m.initials}
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-lg font-medium text-negro mb-1">{m.name}</h3>
                <p class="text-[11px] text-corp uppercase tracking-wide font-medium mb-4">{m.role}</p>
                <p class="text-[15px] text-gris leading-relaxed">{m.bioCompleta}</p>
                {m.linkedin && (
                  <a
                    href={m.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 mt-4 text-[12px] text-medio hover:text-corp transition-colors"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                    </svg>
                    LinkedIn
                  </a>
                )}
              </div>
            </article>
          ))}

          <!-- Tarjeta Red de Expertos Asociados -->
          <article class="bg-white border border-gray-200 rounded overflow-hidden hover:shadow-md transition-shadow">
            <div class="h-48 bg-fondo flex items-center justify-center">
              <div class="w-16 h-16 rounded-full border-2 border-corp flex items-center justify-center text-2xl text-corp">
                ✦
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-medium text-negro mb-1">Red de Expertos Asociados</h3>
              <p class="text-[11px] text-corp uppercase tracking-wide font-medium mb-4">Red especializada</p>
              <p class="text-base text-gris leading-relaxed">
                Istmo Consultores cuenta con una red de profesionales senior que se integran a los proyectos según sus requerimientos específicos, permitiendo escalar capacidades y responder con flexibilidad a cada encargo y contexto.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="relative bg-marino py-20 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img src="/images/title-mapa.webp" alt="" class="w-full h-full object-cover object-center opacity-15" />
        <div class="absolute inset-0 bg-marino/80"></div>
      </div>
      <div class="container relative z-10">
        <div class="max-w-3xl">
          <p class="eyebrow text-cielo">Red de expertos asociados</p>
          <h2 class="font-serif text-2xl md:text-3xl font-medium text-white leading-tight mb-6">Capacidades escalables y especializadas</h2>
          <p class="text-base text-white/60 leading-relaxed mb-6">
            Istmo Consultores cuenta con una <strong class="text-white font-medium">red de expertos asociados</strong>
            que se integran a los proyectos según sus requerimientos, permitiendo escalar capacidades y responder
            con flexibilidad a cada encargo.
          </p>
          <p class="text-base text-white/60 leading-relaxed mb-6">
            Esta red incluye profesionales con trayectoria en derecho, economía, ciencias políticas,
            comunicación estratégica, desarrollo territorial y gestión ambiental, con experiencia en
            sectores públicos, privados y organismos multilaterales.
          </p>
          <div class="border-l-[3px] border-medio pl-6 py-2">
            <p class="text-base text-white/70 leading-relaxed">
              <strong class="text-white font-medium">Nuestro modelo de trabajo colaborativo</strong> nos permite
              ofrecer soluciones integrales sin comprometer la calidad técnica ni la agilidad operativa,
              adaptándonos a las necesidades específicas de cada cliente y proyecto.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
