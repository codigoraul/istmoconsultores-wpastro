---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';

const team = [
  {
    initials: 'FS',
    name: 'Farid Seleme Ruilova',
    role: 'Socio Director',
    bio: 'Abogado y Magíster en Derecho Ambiental. Más de diez años en asuntos públicos, análisis político-regulatorio y relacionamiento institucional en Chile y América Latina.',
    bioCompleta: 'Abogado de la Universidad de Chile y Magíster en Derecho Ambiental de la misma casa de estudios. Cuenta con más de diez años de experiencia en asuntos públicos, análisis político-regulatorio y relacionamiento institucional en Chile y América Latina. Ha asesorado a empresas, asociaciones gremiales y organismos internacionales en estrategias de posicionamiento ante autoridades, diseño de políticas públicas y gestión de riesgos regulatorios. Su práctica se enfoca en sectores regulados como energía, minería, recursos naturales e infraestructura, donde combina rigor técnico con criterio estratégico para anticipar escenarios y construir legitimidad institucional.',
  },
  {
    initials: 'CG',
    name: 'Constanza Guerrero Reyes',
    role: 'Directora Legal',
    bio: 'Abogada especializada en derecho administrativo, inmobiliario y urbanístico. Experta en regulación pública, estructuración jurídica de proyectos y permisos.',
    bioCompleta: 'Abogada de la Universidad de Chile, especializada en derecho administrativo, inmobiliario y urbanístico. Experta en regulación pública, estructuración jurídica de proyectos y tramitación de permisos sectoriales. Ha liderado procesos de due diligence regulatoria, diseño de estrategias de cumplimiento y relacionamiento con autoridades en proyectos de desarrollo urbano, infraestructura y energía. Su enfoque combina conocimiento técnico-jurídico con visión estratégica para anticipar riesgos regulatorios y construir soluciones viables en entornos institucionales complejos.',
  },
  {
    initials: 'JS',
    name: 'Juan Antonio Seleme Yagnam',
    role: 'Director de Proyectos y Desarrollo Territorial',
    bio: 'Ingeniero Civil Industrial y Magíster en Desarrollo Social Rural. Especialista en formulación de proyectos, desarrollo territorial y relacionamiento comunitario.',
    bioCompleta: 'Ingeniero Civil Industrial de la Pontificia Universidad Católica de Chile y Magíster en Desarrollo Social Rural de la Universidad de Chile. Especialista en formulación y evaluación de proyectos, desarrollo territorial y relacionamiento comunitario. Ha liderado procesos de estructuración de proyectos de inversión, diseño de estrategias de relacionamiento con comunidades y fortalecimiento de modelos asociativos en sectores como agricultura, energía y desarrollo urbano. Su práctica integra análisis económico, visión territorial y enfoque participativo para construir proyectos sostenibles y legítimos.',
  },
  {
    initials: 'JR',
    name: 'José Pedro Rossel',
    role: 'Director de Comunicación Estratégica',
    bio: 'Periodista con especialización en política internacional. Trayectoria en el Ministerio de Relaciones Exteriores y la Cámara de Diputadas y Diputados de Chile.',
    bioCompleta: 'Periodista de la Pontificia Universidad Católica de Chile, con especialización en política internacional y comunicación estratégica. Ha desarrollado su carrera en el Ministerio de Relaciones Exteriores de Chile y en la Cámara de Diputadas y Diputados, donde ha liderado estrategias de comunicación institucional, gestión de crisis y posicionamiento público. Su experiencia abarca análisis político, diseño de narrativas estratégicas y relacionamiento con medios de comunicación y stakeholders clave. Combina visión política con capacidad de traducir complejidad técnica en mensajes efectivos.',
  },
  {
    initials: 'JH',
    name: 'Julio Héctor Sánchez Gutiérrez',
    role: 'Subdirector Regional — Centroamérica, el Caribe y México',
    bio: 'Biólogo con más de 30 años en desarrollo sostenible y derecho ambiental. Asesor legislativo para organismos multilaterales en América Latina y el Caribe.',
    bioCompleta: 'Biólogo con más de 30 años de experiencia en desarrollo sostenible, derecho ambiental y políticas públicas en América Latina y el Caribe. Ha sido asesor legislativo para organismos multilaterales, gobiernos nacionales y organizaciones de la sociedad civil en temas de regulación ambiental, cambio climático y gestión de recursos naturales. Su trayectoria incluye el diseño de marcos regulatorios, evaluación de políticas públicas y fortalecimiento institucional en contextos de alta complejidad política y social. Lidera la expansión regional de Istmo Consultores en Centroamérica, el Caribe y México.',
  },
];
---

<Layout title="Equipo — Istmo Consultores">
  <Header />
  <main>
    <PageHero
      variant="reunion"
      title="Equipo"
      subtitle="Criterio estratégico y experiencia multidisciplinaria"
      image="/images/title-equipo.webp"
    />

    <section id="directivo" class="bg-white py-20">
      <div class="container">
        <p class="eyebrow">Equipo directivo</p>
        <h2 class="section-title">Liderazgo con visión estratégica</h2>
        <p class="text-base text-gris leading-relaxed max-w-2xl mb-10">
          La firma opera bajo un modelo ágil que combina un núcleo directivo con una red de 
          especialistas asociados en América Latina y el Caribe.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {team.map(m => (
            <article class="bg-white border border-gray-200 rounded overflow-hidden hover:shadow-md transition-shadow">
              <div class="h-20 bg-marino flex items-center justify-center">
                <div class="w-12 h-12 rounded-full border-2 border-medio flex items-center justify-center text-base font-medium text-cielo">
                  {m.initials}
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-lg font-medium text-negro mb-1">{m.name}</h3>
                <p class="text-[11px] text-corp uppercase tracking-wide font-medium mb-4">{m.role}</p>
                <p class="text-base text-gris leading-relaxed">{m.bioCompleta}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="relative bg-marino py-20 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img src="/images/title-mapa.webp" alt="" class="w-full h-full object-cover object-center opacity-15" />
        <div class="absolute inset-0 bg-marino/80"></div>
      </div>
      <div class="container relative z-10">
        <div class="max-w-3xl">
          <p class="eyebrow text-cielo">Red de expertos asociados</p>
          <h2 class="font-serif text-2xl md:text-3xl font-medium text-white leading-tight mb-6">Capacidades escalables y especializadas</h2>
          <p class="text-base text-white/60 leading-relaxed mb-6">
            Istmo Consultores cuenta con una <strong class="text-white font-medium">red de expertos asociados</strong>
            que se integran a los proyectos según sus requerimientos, permitiendo escalar capacidades y responder
            con flexibilidad a cada encargo.
          </p>
          <p class="text-base text-white/60 leading-relaxed mb-6">
            Esta red incluye profesionales con trayectoria en derecho, economía, ciencias políticas,
            comunicación estratégica, desarrollo territorial y gestión ambiental, con experiencia en
            sectores públicos, privados y organismos multilaterales.
          </p>
          <div class="border-l-[3px] border-medio pl-6 py-2">
            <p class="text-base text-white/70 leading-relaxed">
              <strong class="text-white font-medium">Nuestro modelo de trabajo colaborativo</strong> nos permite
              ofrecer soluciones integrales sin comprometer la calidad técnica ni la agilidad operativa,
              adaptándonos a las necesidades específicas de cada cliente y proyecto.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
